<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText android:id="@+id/etNomeTreino"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nome do Treino" />

    <Spinner
        android:id="@+id/spinnerTipoAtividade"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <EditText android:id="@+id/etDuracao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Tempo de duração"
        android:inputType="number" />

    <EditText
        android:id="@+id/etData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Informe a data do treino (05/05/2026) " />

    <Spinner
        android:id="@+id/spinnerIntensidade"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <CheckBox android:id="@+id/checkTreinou"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Finalizou o Treino? " />

    <Button android:id="@+id/btnSalvar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Salvar" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Spinner android:id="@+id/spinnerFiltro"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content" />

        <CheckBox android:id="@+id/checkFiltroTreino"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Finalizou o Treino? " />

        <Spinner android:id="@+id/spinnerOrdem"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content" />

    </LinearLayout>

    <ListView android:id="@+id/listViewTreinos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
    </LinearLayout>